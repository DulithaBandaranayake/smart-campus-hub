# ===========================================
# Smart Campus Hub - Environment Configuration
# ===========================================
# Copy this file to .env and update values
# Never commit .env files to version control

# ===========================================
# Backend Configuration
# ===========================================

# Server Port (default: 8081)
SERVER_PORT=8081

# Database Configuration (MySQL)
# Make sure MySQL is running and database exists
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/paf_lms?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-mysql-password
SPRING_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver

# JPA Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQL8Dialect

# JWT Secret Key (Change this in production!)
# Generate a secure key using: openssl rand -base64 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# Logging Levels
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG
LOGGING_LEVEL_COM_SMARTCAMPUS_HUB=DEBUG

# ===========================================
# Frontend Configuration
# ===========================================

# API Base URL (for frontend to connect to backend)
VITE_API_BASE_URL=http://localhost:8081/api

# WebSocket URL (if using real-time features)
VITE_WS_URL=ws://localhost:8081/ws

# ===========================================
# Optional Configurations
# ===========================================

# OAuth2 (Google, GitHub, etc.)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Configuration (for notifications)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password
# MAIL_PROTOCOL=smtp
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS_ENABLE=true

# Redis Configuration (for caching/sessions)
# SPRING_REDIS_HOST=localhost
# SPRING_REDIS_PORT=6379
# SPRING_REDIS_PASSWORD=

# File Upload Configuration
# MAX_FILE_SIZE=10MB
# MAX_REQUEST_SIZE=10MB
# UPLOAD_PATH=./uploads

# CORS Configuration
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# CORS_ALLOWED_HEADERS=*
# CORS_ALLOW_CREDENTIALS=true

# ===========================================
# Testing with H2 Database (Optional)
# ===========================================
# To use H2 instead of MySQL, activate the h2 profile:
# ./mvnw spring-boot:run -Dspring-boot.run.profiles=h2
# Or set: SPRING_PROFILES_ACTIVE=h2
